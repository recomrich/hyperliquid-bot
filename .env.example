# Hyperliquid Trading Bot - Environment Variables
# Copy this file to .env and fill in your values

# Hyperliquid wallet private key (NEVER share this)
HL_PRIVATE_KEY=your_private_key_here

# Hyperliquid account address
HL_ACCOUNT_ADDRESS=your_wallet_address_here

# Use testnet (true) or mainnet (false)
HL_TESTNET=true

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
